<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://batchDataDetailView.title"
      focusComponent="form">
    <data>
        <instance id="batchDataDc"
                  class="io.flowset.control.entity.batch.BatchData">
            <loader id="batchDataDl"/>
        </instance>
        <instance id="batchStatisticsDc" class="io.flowset.control.entity.batch.BatchStatisticsData"/>
    </data>
    <actions>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout classNames="pt-xs gap-s" width="100%">
        <div id="mainInfoBox">
            <formLayout id="form" dataContainer="batchDataDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                    <responsiveStep minWidth="30em" columns="2"/>
                    <responsiveStep minWidth="50em" columns="2"/>
                    <responsiveStep minWidth="80em" columns="3"/>
                </responsiveSteps>
                <textField id="idField" property="id" readOnly="true" classNames="pt-s" colspan="2"/>

                <textField id="typeField" property="type" readOnly="true"
                           label="msg://io.flowset.control.entity.batch/RuntimeBatchData.type"
                           classNames="pt-s" width="100%"/>
                <textField id="stateField"
                           property="state"
                           label="msg://io.flowset.control.entity.batch/RuntimeBatchData.state"
                           readOnly="true"
                           classNames="pt-s"
                           width="100%"/>
                <textField id="jobsCreatedField" property="jobsCreated" readOnly="true"
                           label="msg://io.flowset.control.entity.batch/RuntimeBatchData.jobsCreated" visible="false"
                           classNames="pt-s" width="100%"/>
                <textField id="batchJobsPerSeedField"
                           label="msg://io.flowset.control.entity.batch/RuntimeBatchData.batchJobsPerSeed"
                           property="batchJobsPerSeed" readOnly="true" classNames="pt-s"
                           width="100%"/>
                <textField id="invocationsPerBatchJobField" property="invocationsPerBatchJob" readOnly="true"
                           classNames="pt-s" width="100%"/>

                <dateTimePicker id="startTimeField" property="startTime" readOnly="true" classNames="pt-s"
                                width="100%" step="1ms"/>
                <dateTimePicker id="executionStartTimeField" property="executionStartTime" readOnly="true"
                                classNames="pt-s" width="100%" step="1ms"/>
                <dateTimePicker id="endTimeField" property="endTime" readOnly="true" classNames="pt-s"
                                width="100%" step="1ms"/>

                <textField id="seedJobDefinitionIdField" property="seedJobDefinitionId" readOnly="true"
                           classNames="pt-s"/>
                <textField id="monitorJobDefinitionIdField" property="monitorJobDefinitionId" readOnly="true"
                           classNames="pt-s"/>
                <textField id="batchJobDefinitionIdField" property="batchJobDefinitionId" readOnly="true"
                           classNames="pt-s"/>
                <textField id="createUserIdField" property="createUserId" readOnly="true" classNames="pt-s"/>
            </formLayout>
        </div>
        <vbox id="statisticsBox" width="100%" minHeight="20em" themeNames="spacing-s" padding="false" visible="false">
            <fragment id="jobsFragment" class="io.flowset.control.view.batch.jobstatistics.BatchJobStatisticsFragment"/>
        </vbox>

        <hbox id="detailActions" width="100%">
            <button id="closeBtn" action="closeAction"/>
        </hbox>
    </layout>
</view>
